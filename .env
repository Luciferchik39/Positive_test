# .env
DEBUG=True
APP_HOST=0.0.0.0
APP_PORT=8000
PROJECT_NAME=Positive Video Processing

# PostgreSQL
POSTGRES_USER=positive_user
POSTGRES_PASSWORD=positive_pass
POSTGRES_DB=positive_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_VIDEO_PROCESSING=video_processing

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=positive-videos
MINIO_SECURE=False

# Redis
REDIS_URL=redis://redis:6379/0

# JWT (изменить в продакшене!)
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Логирование
LOG_LEVEL=INFO
LOG_FORMAT=console