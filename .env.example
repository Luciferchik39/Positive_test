# Application
DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# PostgreSQL
POSTGRES_USER=positive_user
POSTGRES_PASSWORD=positive_pass
POSTGRES_DB=positive_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://positive_user:positive_pass@postgres:5432/positive_db
DATABASE_POOL_SIZE=20

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_VIDEO_PROCESSING=video_processing

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=positive-videos
MINIO_SECURE=false

# Redis
REDIS_URL=redis://redis:6379/0